# 📧 SMTP (Vardr) — Google App Password
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# 🔐 OIDC (Mimir Dashboard)
YGGDRASIL_CLIENT_ID=
YGGDRASIL_CLIENT_SECRET=
YGGDRASIL_ISSUER=


# ═══════════════════════════════════════
# ⚡ BIFROST — Agent Runtime
# ═══════════════════════════════════════

BIFROST_PORT=
BIFROST_DEFAULT_MODEL=
BIFROST_MAX_ITERATIONS=
BIFROST_MAX_EXECUTION_TIME=

