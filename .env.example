# ╔══════════════════════════════════════════════════════════════╗
# ║  🏰 ASGARD — Centralized Environment Variables             ║
# ║  Single source of truth for ALL services                    ║
# ╚══════════════════════════════════════════════════════════════╝
# Usage:
#   - Docker Compose reads this automatically
#   - Heimdall (host): source scripts/env-export.sh
#   - NEVER commit this file (included in .gitignore)

# ═══════════════════════════════════════
# 💾 INFRASTRUCTURE — Databases
# ═══════════════════════════════════════

MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

POSTGRES_PASSWORD=
NEO4J_PASSWORD=

# ═══════════════════════════════════════
# 🛡️ HEIMDALL — LLM Gateway (on host)
# ═══════════════════════════════════════

HEIMDALL_PORT=
HEIMDALL_API_KEY=
HEIMDALL_MODEL=
HEIMDALL_BACKEND_ENGINE=
HEIMDALL_BACKEND_PORT=
HEIMDALL_GATEWAY_PORT=

# ═══════════════════════════════════════
# 🧠 EMBEDDING — MLX Embedding Server
# ═══════════════════════════════════════

EMBEDDING_PORT=
EMBEDDING_HOST=
EMBEDDING_MODEL=

# ═══════════════════════════════════════
