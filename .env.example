S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

# ═══════════════════════════════════════
# 🔐 VAULT (future use)
# ═══════════════════════════════════════

VAULT_ADDR=
VAULT_TOKEN=
VAULT_MOUNT=
VAULT_PATH=

# ═══════════════════════════════════════
