# ╔══════════════════════════════════════╗
# ║  🏰 ASGARD — Environment Variables  ║
# ╚══════════════════════════════════════╝
# Copy to .env and customize

# ── Infrastructure ──
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=mimir
MYSQL_USER=mimir
MYSQL_PASSWORD=mimir_password
POSTGRES_PASSWORD=zitadel-secret

# ── Yggdrasil (Auth) ──
ZITADEL_PORT=8085
ZITADEL_EXTERNALDOMAIN=localhost
ZITADEL_MASTERKEY=yggdrasil-masterkey-change-me-ok
ZITADEL_ADMIN_EMAIL=admin@asgardai.dev
ZITADEL_ADMIN_PASSWORD=Asgard2026!

# ── Heimdall (on host) ──
HEIMDALL_PORT=8080
EMBEDDING_PORT=8001

# ── Mimir ──
MIMIR_API_PORT=3000
MIMIR_DASHBOARD_PORT=3001
NEO4J_PASSWORD=asgard_neo4j_password

# ── Bifrost ──
BIFROST_PORT=8100

# ── Fenrir ──
FENRIR_PORT=8200

# ── Eir/OpenEMR (--profile full) ──
OPENEMR_PORT=80
OPENEMR_MYSQL_PASSWORD=openemr
OPENEMR_ADMIN_PASSWORD=pass

# ── General ──
LOG_LEVEL=info
RUST_LOG=info
